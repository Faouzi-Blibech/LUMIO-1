# ── DATABASE ──────────────────────────────────────────────────────────────────
# Local dev — docker-compose postgres container
DATABASE_URL=postgresql+asyncpg://lumio:localdev@postgres:5432/lumio

# Production (Supabase) — swap this in for Railway deployment
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_SUPABASE_PASSWORD@db.xtyrnwsgacdzdormernq.supabase.co:5432/postgres

# ── REDIS ─────────────────────────────────────────────────────────────────────
# Local dev — docker-compose redis container
REDIS_URL=redis://redis:6379

# Production (Upstash) — swap for Railway deployment
# REDIS_URL=rediss://YOUR_UPSTASH_URL

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-this-with-a-random-32-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15

# ── OLLAMA (local LLM) ────────────────────────────────────────────────────────
# host.docker.internal reaches the host machine from inside a Docker container
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── GROQ (cloud LLM fallback — free tier, used for Railway production) ────────
# Get free API key at console.groq.com — no credit card needed
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# ── LLM PROVIDER ──────────────────────────────────────────────────────────────
# Set to "ollama" for local dev, "groq" for production
LLM_PROVIDER=ollama

# ── N8N ───────────────────────────────────────────────────────────────────────
N8N_BASE_URL=http://n8n:5678

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── SUPABASE ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xtyrnwsgacdzdormernq.supabase.co
SUPABASE_ANON_KEY=sb_publishable_PU_TTzjGiWvOfi11ExcANw_T7Qau4v6
